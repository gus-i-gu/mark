{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://markei.local/contracts/shared_beta/v3/purchase_registered.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "accountId",
    "deviceId",
    "deviceSequence",
    "eventType",
    "payloadVersion",
    "occurrenceTime",
    "payload",
    "contentHash"
  ],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "accountId": { "type": "string", "format": "uuid" },
    "deviceId": { "type": "string", "format": "uuid" },
    "deviceSequence": { "type": "integer", "minimum": 1 },
    "eventType": { "const": "purchase.registered" },
    "payloadVersion": { "const": 3 },
    "occurrenceTime": { "type": "string", "format": "date-time" },
    "contentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purchase", "productSnapshots"],
      "properties": {
        "productSnapshots": {
          "type": "array",
          "minItems": 1,
          "maxItems": 25,
          "items": { "$ref": "#/$defs/product" }
        },
        "purchase": { "$ref": "#/$defs/purchase" }
      }
    }
  },
  "$defs": {
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currencyCode", "minorUnits"],
      "properties": {
        "currencyCode": { "type": "string", "minLength": 3, "maxLength": 3 },
        "minorUnits": { "type": "integer", "minimum": 0 }
      }
    },
    "quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "kind", "scale", "unit"],
      "properties": {
        "amount": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$" },
        "kind": { "enum": ["MASS", "VOLUME", "COUNT"] },
        "scale": { "const": 6 },
        "unit": { "enum": ["KG", "L", "UNIT"] }
      }
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "accountId", "displayName"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "accountId": { "type": "string", "format": "uuid" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "productCode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["displayValue", "normalizedKey"],
      "properties": {
        "displayValue": { "type": "string", "minLength": 1, "maxLength": 64 },
        "normalizedKey": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "accountId",
        "userProductCode",
        "normalizationVersion",
        "displayName",
        "displayBrand",
        "normalizedName",
        "normalizedBrand",
        "mode",
        "measurementKind",
        "packageQuantity",
        "identityKey"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "accountId": { "type": "string", "format": "uuid" },
        "userProductCode": { "$ref": "#/$defs/productCode" },
        "normalizationVersion": { "const": 3 },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 160 },
        "displayBrand": { "type": "string", "maxLength": 160 },
        "normalizedName": { "type": "string", "minLength": 1, "maxLength": 160 },
        "normalizedBrand": { "type": "string", "maxLength": 160 },
        "mode": { "enum": ["PACKAGED", "BULK"] },
        "measurementKind": { "enum": ["MASS", "VOLUME", "COUNT"] },
        "packageQuantity": { "anyOf": [{ "$ref": "#/$defs/quantity" }, { "type": "null" }] },
        "identityKey": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "purchaseItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "purchaseId",
        "productId",
        "packageCount",
        "purchasedQuantity",
        "lineTotal"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "purchaseId": { "type": "string", "format": "uuid" },
        "productId": { "type": "string", "format": "uuid" },
        "packageCount": { "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }] },
        "purchasedQuantity": { "$ref": "#/$defs/quantity" },
        "lineTotal": { "$ref": "#/$defs/money" }
      }
    },
    "purchase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "accountId",
        "store",
        "personId",
        "paymentMethodId",
        "occurrenceTime",
        "currencyCode",
        "totalMinorUnits",
        "items"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "accountId": { "type": "string", "format": "uuid" },
        "store": { "$ref": "#/$defs/store" },
        "personId": { "type": "null" },
        "paymentMethodId": { "type": "null" },
        "occurrenceTime": { "type": "string", "format": "date-time" },
        "currencyCode": { "type": "string", "minLength": 3, "maxLength": 3 },
        "totalMinorUnits": { "type": "integer", "minimum": 0 },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 25,
          "items": { "$ref": "#/$defs/purchaseItem" }
        }
      }
    }
  }
}
